# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Upstream LLM base URL
CERBAI_LLM_URL=https://llm.internal.example.com

# OAuth2 token endpoint (mTLS required)
CERBAI_TOKEN_ENDPOINT=https://auth.internal.example.com/oauth2/token

# OAuth2 client credentials
CERBAI_CLIENT_ID=my-client-id
CERBAI_CLIENT_SECRET=my-client-secret

# Token cache TTL (default: 5m)
CERBAI_TOKEN_CACHE_TTL=5m
